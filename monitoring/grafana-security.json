{
  "dashboard": {
    "id": null,
    "title": "Stellar-K8s Security Dashboard",
    "tags": ["security", "stellar"],
    "panels": [
      {
        "title": "Security Alerts Firing",
        "type": "stat",
        "targets": [{
          "expr": "ALERTS{alertstate='firing',alertname=~'Operator.*|CVE.*'}",
          "legendFormat": "{{alertname}}"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"}
          }
        }
      },
      {
        "title": "Webhook Response Times (p95)",
        "type": "timeseries",
        "targets": [{"expr": "histogram_quantile(0.95, rate(webhook_request_duration_bucket[5m]))"}]
      },
      {
        "title": "Reconciliation Failures Rate",
        "type": "timeseries",
        "targets": [{"expr": "rate(reconciliation_failures_total[5m])"}]
      },
      {
        "title": "CVE Severity Trend",
        "type": "bargauge",
        "targets": [{"expr": "cve_high_count"}]
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timezone": "browser"
  }
}
